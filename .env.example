# Copy to .env.local and fill in. Never commit real values.
#
#   cp .env.example .env.local
#   docker compose --env-file .env.local up
#
# .env is committed and must stay free of secrets - it only carries COMPOSE_PROJECT_NAME.

COMPOSE_PROJECT_NAME=task-manager

# Signs and validates every access token. Must be at least 256 bits for HS256.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=

# Optional; the application defaults to these.
# JWT_ACCESS_TOKEN_EXPIRATION=3600000
# JWT_REFRESH_TOKEN_EXPIRATION=86400000

# Mongo root account, created by the official image on first start.
MONGO_ROOT_USERNAME=
MONGO_ROOT_PASSWORD=

# Application account, created by docker/mongo/init/init-mongo.js.
# MONGODB_URI must match these credentials.
MONGO_APP_USERNAME=
MONGO_APP_PASSWORD=

# e.g. mongodb://<MONGO_APP_USERNAME>:<MONGO_APP_PASSWORD>@mongo:27017/task-manager?authMechanism=SCRAM-SHA-256
MONGODB_URI=

# Serve /v3/api-docs and /swagger-ui. Off by default. Never enable in production.
# SPRINGDOC_ENABLED=true
